{
  "manifest_version": 3,
  "name": "Meowdo",
  "version": "1.0.1",
  "description": "A fast, private to-do list — organize into lists, see what's left, and get optional reminders. All on your device.",
  "author": "artfred16",
  "homepage_url": "https://artfred16.github.io",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "offscreen"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Meowdo — todos & reminders",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
